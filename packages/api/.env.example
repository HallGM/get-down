# Database (PostgreSQL) — defaults match docker-compose.yml
DB_HOST=localhost
DB_PORT=5433
DB_NAME=get_down
DB_USER=postgres
DB_PASSWORD=postgres

# Auth
JWT_SECRET=

# CORS - URL of the frontend app
FRONTEND_URL=http://localhost:5173

# Airtable migration
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appZXteLrpESv7H8X
API_BASE_URL=http://localhost:3000
MIGRATION_EMAIL=
MIGRATION_PASSWORD=

# Invoice API
INVOICE_SERVICE_URL=http://localhost:5001

# Server
PORT=3000

# Cloudflare R2 (document storage for expense invoices)
# Leave CLOUDFLARE_R2_ACCOUNT_ID empty to use MinIO (local dev).
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=

# Local file storage (MinIO — used automatically when CLOUDFLARE_R2_ACCOUNT_ID is not set)
# MinIO runs via docker-compose on port 9000. These defaults match the docker-compose config.
LOCAL_S3_ENDPOINT=http://localhost:9000
LOCAL_S3_ACCESS_KEY_ID=minioadmin
LOCAL_S3_SECRET_ACCESS_KEY=minioadmin
LOCAL_S3_BUCKET_NAME=get-down-local
