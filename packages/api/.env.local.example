# Local overrides for running migration scripts against localhost
# ---------------------------------------------------------------
# Copy the values below into packages/api/.env (or temporarily override them)
# when you want to run migrate:airtable or migrate:documents against your
# local API instead of production.
#
# dotenv does NOT load this file automatically — it is documentation only.

# Target the local API instead of production
API_BASE_URL=http://localhost:3000
MIGRATION_EMAIL=admin@get-down.com
MIGRATION_PASSWORD=password

# Local file storage (MinIO via docker-compose)
# When CLOUDFLARE_R2_ACCOUNT_ID is absent, the app uses these values.
# Leave CLOUDFLARE_R2_ACCOUNT_ID empty (or remove it) to activate MinIO.
# CLOUDFLARE_R2_ACCOUNT_ID=
LOCAL_S3_ENDPOINT=http://localhost:9000
LOCAL_S3_ACCESS_KEY_ID=minioadmin
LOCAL_S3_SECRET_ACCESS_KEY=minioadmin
LOCAL_S3_BUCKET_NAME=get-down-local
